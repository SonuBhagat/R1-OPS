generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model bookings {
  booking_id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ride_id                String?   @db.Uuid
  booked_by              String?   @db.Uuid
  seats                  Int
  fare_amount            Decimal?  @db.Decimal(10, 2)
  status                 String    @default("pending")
  rider_confirmed        Boolean   @default(false)
  passenger_confirmed    Boolean   @default(false)
  created_at             DateTime? @default(now()) @db.Timestamptz(6)
  is_direct              Boolean?  @default(false)
  negotiated_price       Decimal?  @db.Decimal(10, 2)
  is_middle_route        Boolean?  @default(false)
  middle_route_from_text String?
  middle_route_from_lat  Float?
  middle_route_from_lng  Float?
  middle_route_to_text   String?
  middle_route_to_lat    Float?
  middle_route_to_lng    Float?
  suggested_price        Decimal?  @db.Decimal(10, 2)
  fare_per_seat          Decimal?  @db.Decimal(10, 2)
  vehicle_type           String?
  users                  users?    @relation(fields: [booked_by], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rides                  rides?    @relation(fields: [ride_id], references: [ride_id], onDelete: Cascade, onUpdate: NoAction)
  reviews                reviews[]

  @@index([ride_id], map: "idx_bookings_ride")
  @@index([status], map: "idx_bookings_status")
  @@index([booked_by], map: "idx_bookings_user")
}

model conversations {
  conversation_id                            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ride_id                                    String     @db.Uuid
  participant1_id                            String     @db.Uuid
  participant2_id                            String     @db.Uuid
  created_at                                 DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                                 DateTime?  @default(now()) @db.Timestamptz(6)
  last_message_at                            DateTime?  @default(now()) @db.Timestamptz(6)
  users_conversations_participant1_idTousers users      @relation("conversations_participant1_idTousers", fields: [participant1_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_conversations_participant2_idTousers users      @relation("conversations_participant2_idTousers", fields: [participant2_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rides                                      rides      @relation(fields: [ride_id], references: [ride_id], onDelete: Cascade, onUpdate: NoAction)
  messages                                   messages[]

  @@unique([ride_id, participant1_id, participant2_id])
  @@index([participant1_id], map: "idx_conversations_p1")
  @@index([participant2_id], map: "idx_conversations_p2")
}

model device_tokens {
  user_id    String    @db.Uuid
  token      String
  platform   String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, token])
}

model driver_documents {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  type       String    @db.VarChar(50)
  url        String
  status     String?   @default("pending") @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, type])
}

model emergency_contacts {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  name       String
  phone      String
  relation   String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, phone])
  @@index([user_id], map: "idx_emergency_contacts_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model messages {
  message_id      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String        @db.Uuid
  sender_id       String        @db.Uuid
  content         String
  is_read         Boolean?      @default(false)
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  type            String?       @default("text")
  metadata        Json?         @default("{}")
  conversations   conversations @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade, onUpdate: NoAction)
  users           users         @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id, created_at], map: "idx_messages_conversation")
}

model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  type       String    @db.VarChar(50)
  title      String
  message    String
  data       Json?
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([is_read], map: "idx_notifications_is_read")
  @@index([user_id], map: "idx_notifications_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model otp_sessions {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone_number String
  session_id   String    @unique
  otp_code     String?
  status       String?   @default("pending")
  attempts     Int?      @default(0)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  expires_at   DateTime  @db.Timestamptz(6)
  verified_at  DateTime? @db.Timestamptz(6)
  ip_address   String?
  user_agent   String?

  @@index([expires_at], map: "idx_otp_expires")
  @@index([phone_number], map: "idx_otp_phone")
  @@index([phone_number, status, created_at], map: "idx_otp_phone_status")
  @@index([session_id], map: "idx_otp_session")
  @@index([status], map: "idx_otp_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  review_id                             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ride_id                               String?   @db.Uuid
  booking_id                            String?   @db.Uuid
  reviewer_id                           String    @db.Uuid
  reviewed_user_id                      String    @db.Uuid
  rating                                Int
  comment                               String?
  tags                                  String[]  @default([])
  is_rider_review                       Boolean   @default(false)
  created_at                            DateTime? @default(now()) @db.Timestamptz(6)
  bookings                              bookings? @relation(fields: [booking_id], references: [booking_id], onUpdate: NoAction)
  users_reviews_reviewed_user_idTousers users     @relation("reviews_reviewed_user_idTousers", fields: [reviewed_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_reviews_reviewer_idTousers      users     @relation("reviews_reviewer_idTousers", fields: [reviewer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rides                                 rides?    @relation(fields: [ride_id], references: [ride_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_reviews_created")
  @@index([reviewed_user_id], map: "idx_reviews_reviewed_user")
  @@index([reviewer_id], map: "idx_reviews_reviewer")
  @@index([ride_id], map: "idx_reviews_ride")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model rides {
  ride_id                 String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  posted_by               String?                   @db.Uuid
  type                    String
  from_text               String?
  to_text                 String?
  from_lat                Float?
  from_lng                Float?
  to_lat                  Float?
  to_lng                  Float?
  date_time               DateTime                  @db.Timestamptz(6)
  seats                   Int
  seats_left              Int
  fare_per_seat           Decimal?                  @db.Decimal(10, 2)
  vehicle_type            String?
  status                  String                    @default("open")
  from_geo                Unsupported("geography")?
  to_geo                  Unsupported("geography")?
  route_line              Unsupported("geography")?
  preferences             Json?                     @default("{}")
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  allow_negotiation       Boolean?                  @default(false)
  allow_middle_route      Boolean?                  @default(false)
  estimated_duration_mins Int?
  effective_expiry        DateTime?                 @db.Timestamptz(6)
  bookings                bookings[]
  conversations           conversations[]
  reviews                 reviews[]
  users                   users?                    @relation(fields: [posted_by], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([from_geo], map: "idx_rides_from_geo", type: Gist)
  @@index([from_lat, from_lng, to_lat, to_lng], map: "idx_rides_location")
  @@index([posted_by], map: "idx_rides_posted_by")
  @@index([route_line], map: "idx_rides_route_line", type: Gist)
  @@index([status], map: "idx_rides_status")
  @@index([to_geo], map: "idx_rides_to_geo", type: Gist)
  @@index([type, status, date_time], map: "idx_rides_type_status_datetime")
  @@index([type, status, date_time], map: "idx_rides_type_status_time")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                                                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                               String?
  phone                                              String?              @unique
  email                                              String?              @unique
  role                                               String?
  rating                                             Decimal?             @db.Decimal(3, 2)
  avatar_url                                         String?
  preferences                                        Json?                @default("{}")
  is_verified                                        Boolean?             @default(false)
  created_at                                         DateTime?            @default(now()) @db.Timestamptz(6)
  whatsapp_number                                    String?
  notify_whatsapp                                    Boolean?             @default(false)
  bookings                                           bookings[]
  conversations_conversations_participant1_idTousers conversations[]      @relation("conversations_participant1_idTousers")
  conversations_conversations_participant2_idTousers conversations[]      @relation("conversations_participant2_idTousers")
  device_tokens                                      device_tokens[]
  driver_documents                                   driver_documents[]
  emergency_contacts                                 emergency_contacts[]
  messages                                           messages[]
  notifications                                      notifications[]
  reviews_reviews_reviewed_user_idTousers            reviews[]            @relation("reviews_reviewed_user_idTousers")
  reviews_reviews_reviewer_idTousers                 reviews[]            @relation("reviews_reviewer_idTousers")
  rides                                              rides[]

  @@index([email], map: "idx_users_email")
  @@index([phone], map: "idx_users_phone")
}

model admins {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username   String    @unique
  password   String
  name       String?
  role       String    @default("admin")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model faq_feedback {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String?   @db.Uuid
  faq_question String
  is_helpful   Boolean
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model support_tickets {
  ticket_id  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  category   String
  message    String
  status     String    @default("open")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}
